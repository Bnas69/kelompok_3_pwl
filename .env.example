APP_NAME="Human Resource Analytics Dashboard"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Jakarta
APP_VERSION=1.0.0
APP_STUDY_PROGRAM="Teknik Informatika"
APP_ACADEMIC_YEAR="2025/2026"

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database utama. Saat deploy, isi dengan MySQL server/hosting/VPS, bukan database laptop lokal.
DB_CONNECTION=mysql
DB_HOST=alamat_mysql_server
DB_PORT=3306
DB_DATABASE=nama_database
DB_USERNAME=username_database
DB_PASSWORD=password_database
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

VITE_APP_NAME="Human Resource Analytics Dashboard"

LOGIN_USERNAME=admin
# Buat hash password dengan:
# php -r 'echo password_hash("password_baru", PASSWORD_BCRYPT), PHP_EOL;'
LOGIN_PASSWORD_HASH=
LOGIN_ROLE=admin
LOGIN_DISPLAY_NAME="Admin Kelompok 3"
LOGIN_EMAIL=admin@kelompok3.local

# CSV hanya fallback/import awal. Dashboard utama tetap membaca database MySQL.
HR_FALLBACK_CSV_PATH=public/data/hr_employee_attrition_data.csv
HR_SYNC_LIMIT=15000
HR_MANUAL_SYNC_LIMIT=3000
HR_SYNC_INTERVAL_MINUTES=60
HR_SYNC_HTTP_TIMEOUT=20
HR_SYNC_HTTP_RETRY_TIMES=2
HR_SYNC_HTTP_RETRY_SLEEP=500
HR_DASHBOARD_CACHE_SECONDS=300
